{
  "manifest_version": 3,
  "name": "Watch Together Sync",
  "version": "0.1.0",
  "description": "Sync HTML5 video playback with friends and chat in fullscreen.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "extension/background.js"
  },
  "action": {
    "default_popup": "extension/popup.html",
    "default_title": "Watch Together Sync"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "extension/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
